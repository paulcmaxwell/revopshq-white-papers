# --- HubSpot lead capture (optional but recommended) ---
# Private App token with crm.objects.contacts.write scope.
# Without it, leads are still validated, logged, and the PDF still unlocks —
# they just aren't pushed to the CRM.
HUBSPOT_PRIVATE_APP_TOKEN=

# Optional: names of EXISTING custom contact properties to record extra context.
# Leave blank unless you've created these in HubSpot (Settings → Properties).
# The lead sync retries with standard fields only if a property is unknown.
HUBSPOT_HUBSPOT_USER_PROPERTY=
HUBSPOT_PAPER_PROPERTY=
